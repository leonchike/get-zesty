# Recipe Manager MCP Environment Configuration

# API Base URL - change to production URL when deploying
API_BASE_URL=http://localhost:3000

# MCP API Key - must match the key in your Next.js app .env file
MCP_API_KEY=your-mcp-api-key-here

# Default User ID for testing
DEFAULT_USER_ID=your-user-id-here

# Supabase Database Connection (for direct database access if needed)
DATABASE_URL=your-supabase-connection-string
